extends ../layout/inicio

block header
    header.relative(style="z-index: 9999;")
        include ../layout/headerPrincipal

block footer
    include ../layout/footer

block content
    main.mx-auto.pt-32.pb-16.w-full.max-w-5xl.px-6.flex-grow
        div.py-10
            h1.text-center.text-3xl.font-black.text-slate-800.tracking-tighter(data-aos="fade-down")= pagina

            .mt-12.mx-auto.max-w-md(data-aos="zoom-in")
                //- Enlace corregido a la ruta de edición
                a(href="/auth/editarRancho" class="block bg-white shadow-xl rounded-[3rem] overflow-hidden hover:shadow-2xl transition-all duration-300 border border-slate-100 group")
                    
                    div.p-10.flex.flex-col.items-center.gap-6
                        //- Contenedor de Imagen o Icono
                        div(class="w-32 h-32 rounded-full bg-slate-50 flex items-center justify-center overflow-hidden border-4 border-white shadow-md group-hover:scale-105 transition-transform")
                            if rancho.fotografia
                                img(src=`/uploads/${rancho.fotografia}` class="w-full h-full object-cover")
                            else
                                i(class="fas fa-tractor text-5xl text-[#9ba657]")
                        
                        div.text-center
                            p(class="text-[#9ba657] text-[10px] uppercase font-black tracking-[0.2em] mb-2") Unidad de Producción Activa
                            h3.text-3xl.font-black.text-slate-800.tracking-tight= rancho.nombre
                            
                            - const tieneUbicacion = rancho.municipio && rancho.estado
                            p.text-slate-500.mt-3.font-medium
                                if tieneUbicacion
                                    i.fas.fa-location-dot.mr-2.text-slate-300
                                    | #{rancho.municipio}, #{rancho.estado}
                                else
                                    i.fas.fa-map-marker-alt.mr-2.text-slate-300
                                    | Ubicación no especificada
                    
                    //- Footer de la Tarjeta (Acción)
                    div.bg-slate-50.px-10.py-6.flex.justify-between.items-center.border-t.border-slate-100
                        span(class="text-[10px] font-black uppercase text-slate-400 tracking-widest") Gestionar Detalles
                        div(class="w-10 h-10 rounded-full bg-white flex items-center justify-center shadow-sm group-hover:bg-[#9ba657] transition-all")
                            i(class="fas fa-arrow-right text-slate-300 group-hover:text-white text-sm")