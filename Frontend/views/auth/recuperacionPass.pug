extends ../layout/inicio

block content
  - var ocultarTodo = false

  .min-h-screen.flex.items-center.justify-center.bg-slate-100.px-4.py-4.relative.pointer-events-none(style="z-index: 1;")
    div(class="max-w-4xl w-full bg-white shadow-2xl overflow-hidden border border-slate-200 flex flex-col pointer-events-auto rounded-[3rem] md:flex-row")
      
      //- Columna Izquierda (Informativa)
      .relative.flex-1.p-10.text-white.flex.flex-col.justify-center.items-center.text-center(style="background-color: #9BA657;")
        div(data-aos="fade-up")
          .mb-4
            img.mx-auto(src="/assets/logoBlanco.png" alt="Logo TalTech" class="h-20 w-auto drop-shadow-lg")
          h2.text-3xl.font-black.tracking-tighter.leading-tight Recuperar Acceso
          p.mt-3.text-sm.text-white.opacity-80.font-medium No te preocupes, te enviaremos las instrucciones a tu correo.
        .absolute.bottom-0.left-0.w-full.h-20.opacity-20(style="background: linear-gradient(transparent, rgba(255,255,255,0.4));")

      //- Columna Derecha (Formulario)
      div(class="flex-1 p-8 flex flex-col justify-center lg:p-12")
        div(data-aos="fade-left")
          h1.text-3xl.font-black.text-slate-900 ¿Olvidaste tu contraseña?
          p.text-slate-500.mt-1 Introduce tu email para restablecerla.

          if errores
            div.mt-4.space-y-2
              each error in errores
                p.bg-red-100.text-red-700.text-xs.p-3.rounded-xl.font-bold.border-l-4.border-red-500= error.msg

          form.mt-8.space-y-4(action="/auth/recuperacionPass" method="POST" noValidate)
            input(type="hidden" name="_csrf" value= csrfToken)
            
            div
              label.block.text-xs.font-black.text-slate-400.uppercase.tracking-widest.mb-2 Correo Electrónico
              input.w-full.px-4.py-3.rounded-2xl.border.border-slate-200.bg-slate-50.transition-all(
                type="email" 
                name="email" 
                placeholder="ejemplo@correo.com" 
                required 
                class="focus:ring-2 focus:ring-[#9BA657] outline-none"
              )
            
            .flex.flex-col.gap-4.pt-4
              button.w-full.py-4.rounded-2xl.text-white.font-bold.shadow-xl.transition-all(
                type="submit" 
                style="background-color: #9BA657;" 
                class="hover:brightness-110 shadow-[#9BA657]/20"
              ) Enviar Instrucciones
              
              .flex.items-center.justify-between.mt-2
                p.text-sm.text-slate-500 ¿Recordaste tu clave? 
                  a.font-bold(href="/auth/login" style="color: #9BA657;" class="hover:underline ml-1") Inicia Sesión
                
                a.font-bold(href="/auth/registro" style="color: #9BA657;" class="text-[11px] uppercase tracking-tighter hover:underline") Crear cuenta