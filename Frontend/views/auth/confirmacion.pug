extends ../layout/inicio

block content
  .min-h-screen.flex.items-center.justify-center.bg-slate-100.px-4.relative
    .max-w-md.w-full.bg-white.shadow-2xl.overflow-hidden.border.border-slate-200(class="rounded-[2.5rem]")
      
      //- Cabecera Dinámica (Verde para éxito, Rojo para error)
      div(class=`p-10 text-center ${error ? 'bg-red-500' : 'bg-[#9BA657]'}`)
        if error
          svg.w-20.h-20.text-white.mx-auto.mb-4(fill="none" stroke="currentColor" viewBox="0 0 24 24")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z")
        else
          svg.w-20.h-20.text-white.mx-auto.mb-4(fill="none" stroke="currentColor" viewBox="0 0 24 24")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z")
        
        h1.text-2xl.font-black.text-white.uppercase.tracking-tighter= pagina

      .p-8.text-center
        p.text-slate-600.font-medium.text-lg.mb-8= mensaje
        
        if !error
          a.block.w-full.py-4.rounded-2xl.text-white.font-bold.shadow-xl.transition-all(href="/auth/login" style="background-color: #9BA657;" class="hover:brightness-110") Ir al Inicio de Sesión
        else
          a.block.w-full.py-4.rounded-2xl.bg-slate-800.text-white.font-bold.shadow-xl.transition-all(href="/auth/registro" class="hover:bg-slate-900") Volver al Registro