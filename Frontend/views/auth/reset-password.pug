extends ../layout/inicio

block content
  - var ocultarTodo = false

  .min-h-screen.flex.items-center.justify-center.bg-slate-100.px-4.py-4
    div(class="max-w-4xl w-full bg-white shadow-2xl overflow-hidden border border-slate-200 flex flex-col rounded-[3rem] md:flex-row")
      
      //- Columna Izquierda
      .relative.flex-1.p-10.text-white.flex.flex-col.justify-center.items-center.text-center(style="background-color: #9BA657;")
        div(data-aos="fade-up")
          .mb-4
            img.mx-auto(src="/assets/logoBlanco.png" alt="Logo TalTech" class="h-20 w-auto drop-shadow-lg")
          h2.text-3xl.font-black.tracking-tighter.leading-tight Nueva Contraseña
          p.mt-3.text-sm.text-white.opacity-80.font-medium Define una clave segura para proteger tus datos ganaderos.

      //- Columna Derecha
      div(class="flex-1 p-8 flex flex-col justify-center lg:p-12")
        div(data-aos="fade-left")
          h1.text-3xl.font-black.text-slate-900 Restablecer clave
          p.text-slate-500.mt-1 Ingresa tu nueva contraseña a continuación.

          if errores
            div.mt-4.space-y-2
              each error in errores
                p.bg-red-100.text-red-700.text-xs.p-3.rounded-xl.font-bold.border-l-4.border-red-500= error.msg

          //- El action vacío hace que se envíe a la URL actual (que incluye el token)
          form.mt-8.space-y-4(method="POST" noValidate)
            input(type="hidden" name="_csrf" value= csrfToken)
            
            div
              label.block.text-xs.font-black.text-slate-400.uppercase.tracking-widest.mb-2 Nueva Contraseña
              input.w-full.px-4.py-3.rounded-2xl.border.border-slate-200.bg-slate-50.transition-all(
                type="password" 
                name="password" 
                placeholder="Mínimo 6 caracteres" 
                required 
                class="focus:ring-2 focus:ring-[#9BA657] outline-none"
              )
            
            button.w-full.py-4.rounded-2xl.text-white.font-bold.shadow-xl.transition-all.mt-4(
              type="submit" 
              style="background-color: #9BA657;" 
              class="hover:brightness-110"
            ) Guardar Nueva Contraseña